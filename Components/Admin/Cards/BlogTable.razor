@using DotnetNiger.UI.Models.Responses
<div class="bg-white rounded-lg shadow overflow-hidden">
      <div class="overflow-x-auto">
            <table class="w-full">
                  <thead class="bg-gray-100 border-b border-gray-200">
                        <tr>
                              <th class="px-6 py-4 text-left Button text-text">Titre</th>
                              <th class="px-6 py-4 text-left Button text-text">Auteur</th>
                              <th class="px-6 py-4 text-left Button text-text">Catégorie</th>
                              <th class="px-6 py-4 text-left Button text-text">Rôle</th>
                              <th class="px-6 py-4 text-left Button text-text">Statut</th>
                              <th class="px-6 py-4 text-left Button text-text">Date</th>
                              <th class="px-6 py-4 text-left Button text-text">Actions</th>
                        </tr>
                  </thead>
                  <tbody class="divide-y divide-gray-200">
                        <tr class="hover:bg-gray-50 transition">
                              <td class="px-6 py-4 text-sm text-text font-medium">Introduction à Blazor WebAssembly</td>
                              <td class="px-6 py-4 text-sm text-text">Abdoul Malik</td>
                              <td class="px-6 py-4 text-sm text-text">Tutorial</td>
                              <td class="px-6 py-4 text-sm text-text">
                                    <span
                                    class="px-3 py-1 bg-gray-100 text-gray-800 rounded-full text-xs font-medium">Admin</span>
                              </td>
                              <td class="px-6 py-4 text-sm">
                                    <div class="flex items-center gap-2">
                                          <div class="bg-green-500 w-3 h-3 rounded-full"></div>
                                          <span class="text-gray-700">Publié</span>
                                    </div>
                              </td>
                              <td class="px-6 py-4 text-sm text-text">01/04/2026 12:15</td>
                              <td class="px-6 py-4 text-sm">
                                    <div class="flex gap-3">
                                          <button class="text-text hover:text-blue-600 transition" title="Voir">
                                                <i class="fas fa-eye"></i>
                                          </button>
                                          <button class="text-text hover:text-yellow-600 transition" title="Éditer">
                                                <i class="fas fa-edit"></i>
                                          </button>
                                          <button class="text-text hover:text-red-600 transition" title="Supprimer">
                                                <i class="fas fa-trash-alt"></i>
                                          </button>
                                    </div>
                              </td>
                        </tr>
                  </tbody>
            </table>
      </div>
</div>
