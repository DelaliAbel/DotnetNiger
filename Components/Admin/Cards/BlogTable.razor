@* Composant tableau : affichage des posts avec actions voir/éditer/supprimer. *@
@using DotnetNiger.UI.Models.Responses
@inject NavigationManager NavigationManager

<div class="overflow-hidden rounded-lg bg-white shadow">
      <div class="overflow-x-auto">
            <table class="w-full">
                  <thead class="border-b border-gray-200">
                        <tr>
                              <th class="Button px-6 py-4 text-left text-text">Titre</th>
                              <th class="Button px-6 py-4 text-left text-text">Auteur</th>
                              <th class="Button px-6 py-4 text-left text-text">Categorie</th>
                              <th class="Button px-6 py-4 text-left text-text">Vue</th>
                              <th class="Button px-6 py-4 text-left text-text">Statut</th>
                              <th class="Button px-6 py-4 text-left text-text">Date</th>
                              <th class="Button px-6 py-4 text-left text-text">Actions</th>
                        </tr>
                  </thead>
                  <tbody class="divide-y divide-gray-200">
                        @foreach (var post in Posts)
                        {
                              <tr class="transition hover:bg-gray-50">
                                    <td class="px-6 py-4 text-sm font-medium text-text">@post.Title</td>
                                    <td class="px-6 py-4 text-sm text-text">@post.AuthorName</td>
                                    <td class="px-6 py-4 text-sm text-text">@string.Join(", ", post.Categories.Select(c => c.Name))</td>
                                    <td class="px-6 py-4 text-sm text-text">
                                          <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-800">@post.ViewCount</span>
                                    </td>
                                    <td class="px-6 py-4 text-sm">
                                          @if (post.PublishedAt != DateTime.MinValue)
                                          {
                                                <span class="inline-flex items-center rounded-md bg-[#73F8AB] px-3 py-1.5 text-xs font-semibold text-[#27AE60]">Publié</span>
                                          }
                                          else
                                          {
                                                <span class="inline-flex items-center rounded-md bg-amber-100 px-3 py-1.5 text-xs font-semibold text-amber-700">En attente</span>
                                          }
                                    </td>
                                    <td class="px-6 py-4 text-sm text-text">@post.PublishedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="px-6 py-4 text-sm">
                                          <div class="flex gap-3">
                                                <button @onclick='() => NavigationManager.NavigateTo($"/admin/blog/{post.Id}")'
                                                        class="text-text transition hover:text-blue-600" title="Voir">
                                                      <i class="fas fa-eye"></i>
                                                </button>
                                                <button @onclick='() => NavigationManager.NavigateTo($"/admin/blog/edit/{post.Id}")'
                                                        class="text-text transition hover:text-yellow-600" title="Editer">
                                                      <i class="fas fa-edit"></i>
                                                </button>
                                                <button @onclick="() => OnDelete.InvokeAsync(post.Id)"
                                                        class="text-text transition hover:text-red-600" title="Supprimer">
                                                      <i class="fas fa-trash-alt"></i>
                                                </button>
                                          </div>
                                    </td>
                              </tr>
                        }
                  </tbody>
            </table>
      </div>
</div>

@code {
      [Parameter] public List<PostDto> Posts { get; set; } = new();
      [Parameter] public EventCallback<Guid> OnDelete { get; set; }
}
