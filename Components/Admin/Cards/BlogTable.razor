@using DotnetNiger.UI.Models.Responses
<div class="overflow-hidden rounded-lg bg-white shadow">
      <div class="overflow-x-auto">
            <table class="w-full">
                  <thead class="border-b border-gray-200 bg-gray-100">
                        <tr>
                              <th class="Button px-6 py-4 text-left text-text">Titre</th>
                              <th class="Button px-6 py-4 text-left text-text">Auteur</th>
                              <th class="Button px-6 py-4 text-left text-text">Catégorie</th>
                              <th class="Button px-6 py-4 text-left text-text">Rôle</th>
                              <th class="Button px-6 py-4 text-left text-text">Statut</th>
                              <th class="Button px-6 py-4 text-left text-text">Date</th>
                              <th class="Button px-6 py-4 text-left text-text">Actions</th>
                        </tr>
                  </thead>
                  <tbody class="divide-y divide-gray-200">
                        @for(int i = 0;i < 5;i++){

                        <tr class="transition hover:bg-gray-50">
                              <td class="px-6 py-4 text-sm font-medium text-text">Introduction à Blazor WebAssembly</td>
                              <td class="px-6 py-4 text-sm text-text">Abdoul Malik</td>
                              <td class="px-6 py-4 text-sm text-text">Tutorial</td>
                              <td class="px-6 py-4 text-sm text-text">
                                    <span
                                    class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-800">Admin</span>
                              </td>
                              <td class="px-6 py-4 text-sm">
                                    <div class="flex items-center gap-2">
                                          <div class="h-3 w-3 rounded-full bg-green-500"></div>
                                          <span class="text-gray-700">Publié</span>
                                    </div>
                              </td>
                              <td class="px-6 py-4 text-sm text-text">01/04/2026 12:15</td>
                              <td class="px-6 py-4 text-sm">
                                    <div class="flex gap-3">
                                          <button class="text-text transition hover:text-blue-600" title="Voir">
                                                <i class="fas fa-eye"></i>
                                          </button>
                                          <button class="text-text transition hover:text-yellow-600" title="Éditer">
                                                <i class="fas fa-edit"></i>
                                          </button>
                                          <button class="text-text transition hover:text-red-600" title="Supprimer">
                                                <i class="fas fa-trash-alt"></i>
                                          </button>
                                    </div>
                              </td>
                        </tr>
                        }
                  </tbody>
            </table>
      </div>
      <div class="flex h-16 items-center justify-end bg-gray-100 px-6">
            <div class="flex h-[40px] w-auto items-center justify-center gap-[32px]">
            <div>
                  <button class="flex h-[40px] w-[98px] items-center justify-center rounded-lg bg-secondary">
                        <span class="Button">Prec</span>
                  </button>
            </div>
            <div>
                  <button class="flex h-[40px] w-[38px] items-center justify-center rounded-lg bg-secondary">
                        <span class="Button">1</span>
                  </button>
            </div>
            <div>
                  <button class="flex h-[40px] w-[38px] items-center justify-center rounded-lg bg-secondary">
                        <span class="Button">2</span>
                  </button>
            </div>
            <div>
                  <button class="flex h-[40px] w-[98px] items-center justify-center rounded-lg bg-secondary">
                        <span class="Button">Suiv</span>
                  </button>
            </div>
      </div>
      </div>
      
</div>
