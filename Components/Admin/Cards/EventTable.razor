@using DotnetNiger.UI.Components.Admin.Cards
@using DotnetNiger.UI.Models.Responses
@inject NavigationManager Navigation

<div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="w-full">
        <thead class="bg-gray-50 border-b">
            <tr>
                <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Evènement</th>
                <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Organisateur</th>
                <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Type</th>
                <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Date début</th>
                <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Statut</th>
                <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Inscrits</th>
                <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ev in Event)
            {
                <tr class="border-b hover:bg-gray-50">
                    <td class="px-6 py-4 text-sm font-medium">@ev.Title</td>
                    <td class="px-6 py-4 text-sm">@ev.OrganizerName</td>
                    <td class="px-6 py-4 text-sm">@ev.EventType</td>
                    <td class="px-6 py-4 text-sm whitespace-nowrap">@ev.StartDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="px-6 py-4 text-sm">
                        @if (ev.IsArchived)
                        {
                            <span class="inline-flex items-center rounded-md bg-gray-100 px-3 py-1.5 text-xs font-semibold text-gray-700">Archivé</span>
                        }
                        else if (ev.IsPublished)
                        {
                            <span class="inline-flex items-center rounded-md bg-[#73F8AB] px-3 py-1.5 text-xs font-semibold text-[#27AE60]">Publié</span>
                        }
                        else
                        {
                            <span class="inline-flex items-center rounded-md bg-amber-100 px-3 py-1.5 text-xs font-semibold text-amber-700">En attente</span>
                        }
                    </td>
                    <td class="px-6 py-4 text-sm">@ev.RegisteredCount / @ev.Capacity</td>
                    <td class="px-6 py-4 text-sm">
                        @{ 
                            var isArchived = ev.IsArchived;
                            var isPublished = ev.IsPublished && !isArchived;
                            var isPending = !isPublished && !isArchived;
                        }
                        <div class="flex gap-2">
                            <button @onclick='() => Navigation.NavigateTo($"/admin/events/edit/{ev.Id}")'
                                    class="text-gray-600 hover:text-blue-600" title="Voir">
                                <i class="fas fa-eye"></i>
                            </button>
                            @if (!isPublished)
                            {
                                <button @onclick="() => OnSetPublished.InvokeAsync(ev.Id)"
                                        class="text-gray-600 hover:text-green-600" title="Publier">
                                    <i class="fas fa-circle-check"></i>
                                </button>
                            }
                            @if (!isPending)
                            {
                                <button @onclick="() => OnSetPending.InvokeAsync(ev.Id)"
                                        class="text-gray-600 hover:text-amber-500" title="Mettre en attente">
                                    <i class="fas fa-clock"></i>
                                </button>
                            }
                            @if (!isArchived)
                            {
                                <button @onclick="() => OnSetArchived.InvokeAsync(ev.Id)"
                                        class="text-gray-600 hover:text-gray-900" title="Archiver">
                                    <i class="fas fa-box-archive"></i>
                                </button>
                            }
                            <button @onclick="() => OnDelete.InvokeAsync(ev.Id)"
                                    class="text-gray-600 hover:text-red-600" title="Supprimer">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@code{
    [Parameter] public List<EventDto> Event { get; set; } = new();
    [Parameter] public EventCallback<Guid> OnDelete { get; set; }
    [Parameter] public EventCallback<Guid> OnSetPending { get; set; }
    [Parameter] public EventCallback<Guid> OnSetPublished { get; set; }
    [Parameter] public EventCallback<Guid> OnSetArchived { get; set; }

}