@* Composant admin : barre latérale de navigation (responsive + mode réduit). *@
@inject IProfileService ProfileService

<div class="h-full">
      <aside class="hidden h-full flex-col justify-between bg-secondary text-white shadow-lg transition-all duration-300 sm:flex @DesktopSidebarWidthClass">
            <div>
                  <NavLink href="/admin/profile" class="flex items-center gap-3 border-b border-slate-700/60 px-4 py-4 bg-active/80" ActiveClass="bg-active">
                        <div class="flex h-[46px] w-[46px] items-center justify-center overflow-hidden rounded-full bg-slate-700 text-lg font-semibold text-white">
                              @if (HasAvatar)
                              {
                                    <img src="@AvatarUrl" class="h-full w-full object-cover" alt="Avatar de @DisplayName">
                              }
                              else
                              {
                                    <span>@UserInitial</span>
                              }
                        </div>

                        @if (!IsCollapsed)
                        {
                              <div class="min-w-0">
                                    <span class="Button block truncate text-white">@DisplayName</span>
                                    <span class="Badge block truncate text-[#04FE00]">@PrimaryRole</span>
                              </div>
                        }
                  </NavLink>

                  <nav class="mt-4 flex-1 space-y-2 px-3">
                        <NavLink href="/admin/dashboard" class="flex items-center gap-2 rounded-lg px-3 py-3 transition-colors hover:bg-hover" ActiveClass="bg-active">
                              <i class="fas fa-gauge w-8 text-2xl"></i>
                              @if (!IsCollapsed)
                              {
                                    <span class="Link">Dashboard</span>
                              }
                        </NavLink>

                        <NavLink href="/admin/users" class="flex items-center gap-2 rounded-lg px-3 py-3 transition-colors hover:bg-hover" ActiveClass="bg-active">
                              <i class="fas fa-user w-8 text-2xl"></i>
                              @if (!IsCollapsed)
                              {
                                    <span class="Link">Utilisateurs</span>
                              }
                        </NavLink>

                        <NavLink href="/admin/blog" class="flex items-center gap-2 rounded-lg px-3 py-3 transition-colors hover:bg-hover" ActiveClass="bg-active">
                              <i class="fas fa-newspaper w-8 text-2xl"></i>
                              @if (!IsCollapsed)
                              {
                                    <span class="Link">Blog</span>
                              }
                        </NavLink>

                        <NavLink href="/admin/events" class="flex items-center gap-2 rounded-lg px-3 py-3 transition-colors hover:bg-hover" ActiveClass="bg-active">
                              <i class="fas fa-calendar w-8 text-2xl"></i>
                              @if (!IsCollapsed)
                              {
                                    <span class="Link">Événements</span>
                              }
                        </NavLink>

                        <NavLink href="/admin/ressources" class="flex items-center gap-2 rounded-lg px-3 py-3 transition-colors hover:bg-hover" ActiveClass="bg-active">
                              <i class="fas fa-folder w-8 text-2xl"></i>
                              @if (!IsCollapsed)
                              {
                                    <span class="Link">Ressources</span>
                              }
                        </NavLink>
                  </nav>
            </div>

            <div class="border-t border-slate-700 p-4">
                  <NavLink href="/" class="flex items-center gap-2 text-gray-300 transition-colors hover:text-white">
                        <i class="fas fa-arrow-left mr-3"></i>
                        @if (!IsCollapsed)
                        {
                              <span>Retour au site</span>
                        }
                  </NavLink>
            </div>
      </aside>

      <div class="fixed inset-0 z-40 bg-black/50 sm:hidden @(IsOpen ? string.Empty : "hidden")" @onclick="Closed"></div>

      <aside class="fixed top-0 left-0 z-50 flex h-full w-64 flex-col justify-between bg-secondary text-white shadow-lg transition-transform duration-300 sm:hidden @(IsOpen ? "translate-x-0" : "-translate-x-full")">
            <div>
                  <div class="flex h-16 items-center gap-3 bg-active px-5 text-2xl font-bold">
                        <img src="/Logo.svg" alt="Logo du Dotnet Niger" class="h-10 w-10">
                        <span class="Link">Dotnet Niger</span>
                  </div>

                  <NavLink href="/admin/profile" class="mt-4 flex items-center gap-3 px-5 py-3" ActiveClass="bg-active/80" @onclick="Closed">
                        <div class="flex h-[46px] w-[46px] items-center justify-center overflow-hidden rounded-full bg-slate-700 text-lg font-semibold text-white">
                              @if (HasAvatar)
                              {
                                    <img src="@AvatarUrl" class="h-full w-full object-cover" alt="Avatar de @DisplayName">
                              }
                              else
                              {
                                    <span>@UserInitial</span>
                              }
                        </div>

                        <div class="min-w-0">
                              <span class="Button block truncate text-white">@DisplayName</span>
                              <span class="Badge block truncate text-[#04FE00]">@PrimaryRole</span>
                        </div>
                  </NavLink>

                  <nav class="mt-3 flex-1 space-y-2 px-4">
                        <NavLink href="/admin/dashboard" class="flex items-center gap-2 rounded-lg px-3 py-3 transition-colors hover:bg-hover" ActiveClass="bg-active" @onclick="Closed">
                              <i class="fas fa-gauge w-8 text-2xl"></i>
                              <span class="Link">Dashboard</span>
                        </NavLink>

                        <NavLink href="/admin/users" class="flex items-center gap-2 rounded-lg px-3 py-3 transition-colors hover:bg-hover" ActiveClass="bg-active" @onclick="Closed">
                              <i class="fas fa-user w-8 text-2xl"></i>
                              <span class="Link">Utilisateurs</span>
                        </NavLink>

                        <NavLink href="/admin/blog" class="flex items-center gap-2 rounded-lg px-3 py-3 transition-colors hover:bg-hover" ActiveClass="bg-active" @onclick="Closed">
                              <i class="fas fa-newspaper w-8 text-2xl"></i>
                              <span class="Link">Blog</span>
                        </NavLink>

                        <NavLink href="/admin/events" class="flex items-center gap-2 rounded-lg px-3 py-3 transition-colors hover:bg-hover" ActiveClass="bg-active" @onclick="Closed">
                              <i class="fas fa-calendar w-8 text-2xl"></i>
                              <span class="Link">Événements</span>
                        </NavLink>

                        <NavLink href="/admin/ressources" class="flex items-center gap-2 rounded-lg px-3 py-3 transition-colors hover:bg-hover" ActiveClass="bg-active" @onclick="Closed">
                              <i class="fas fa-folder w-8 text-2xl"></i>
                              <span class="Link">Ressources</span>
                        </NavLink>
                  </nav>
            </div>

            <div class="mb-[5%] border-t border-slate-700 p-4">
                  <NavLink href="/" class="flex items-center gap-2 text-gray-300 transition-colors hover:text-white" @onclick="Closed">
                        <i class="fas fa-arrow-left mr-2"></i>
                        <span>Retour au site</span>
                  </NavLink>
            </div>
      </aside>
</div>

@code {
      [Parameter]
      public bool IsCollapsed { get; set; }

      [Parameter]
      public EventCallback Closed { get; set; }

      [Parameter]
      public bool IsOpen { get; set; }

      private UserDto? profil;

      private string DesktopSidebarWidthClass => IsCollapsed ? "w-20" : "w-64"; 

      private string DisplayName => string.IsNullOrWhiteSpace(profil?.Username) ? "Administrateur" : profil.Username;

      private string PrimaryRole => profil?.Roles?.FirstOrDefault() ?? "Membre";

      private string AvatarUrl => profil?.AvatarUrl ?? string.Empty;

      private bool HasAvatar => !string.IsNullOrWhiteSpace(AvatarUrl);

      private string UserInitial => DisplayName.Substring(0, 1).ToUpperInvariant();

      protected override async Task OnInitializedAsync()
      {
            profil = await ProfileService.GetProfileAsync();
      }
}