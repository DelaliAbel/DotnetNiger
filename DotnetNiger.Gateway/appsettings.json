{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.ReverseProxy": "Information"
    }
  },
  "AllowedHosts": "*",
  "RateLimit": {
    "MaxRequestsPerMinute": 100
  },
  "Services": {
    "Identity": {
      "BaseUrl": "http://localhost:5075",
      "Timeout": 30
    },
    "Community": {
      "BaseUrl": "http://localhost:5269",
      "Timeout": 30
    }
  },
  
  "Jwt": {
    "Issuer": "DotnetNiger.Identity",
    "Audience": "DotnetNiger.Identity.Client",
    "Key": "__JWT_KEY__"
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/identity/{**catch-all}"
        }
      },
      "community-route": {
        "ClusterId": "community-cluster",
        "Match": {
          "Path": "/community/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5075/"
          }
        }
      },
      "community-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5269/"
          }
        }
      }
    }
  }
}
