{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.ReverseProxy": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/identity/{**catch-all}"
        }
      },
      "identity-swagger": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/swagger/identity/{**catch-all}"
        },
        "Transforms": [{ "PathPattern": "/swagger/{**catch-all}" }]
      },
      "community-route": {
        "ClusterId": "community-cluster",
        "Match": {
          "Path": "/community/{**catch-all}"
        }
      },
      "community-swagger": {
        "ClusterId": "community-cluster",
        "Match": {
          "Path": "/swagger/community/{**catch-all}"
        },
        "Transforms": [{ "PathPattern": "/swagger/{**catch-all}" }]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5075/"
          }
        }
      },
      "community-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5269/"
          }
        }
      }
    }
  }
}
