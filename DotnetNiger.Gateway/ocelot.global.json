{
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5000",
    "RequestIdKey": "X-Request-ID",
    "RateLimitOptions": {
      "ClientIdHeader": "ClientId",
      "QuotaExceededMessage": "Trop de requetes. Reessayez dans un moment.",
      "HttpStatusCode": 429
    }
  },
  "SwaggerEndPoints": [
    {
      "Key": "identity",
      "Config": [
        {
          "Name": "Identity API",
          "Version": "v1",
          "Url": "http://localhost:5075/swagger/v1/swagger.json"
        }
      ]
    },
    {
      "Key": "community",
      "Config": [
        {
          "Name": "Community API",
          "Version": "v1",
          "Url": "http://localhost:5269/swagger/v1/swagger.json"
        }
      ]
    }
  ]
}
