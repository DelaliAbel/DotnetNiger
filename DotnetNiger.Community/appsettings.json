{
  "ConnectionStrings": {
    "DotnetNigerDb": "Data Source=../DotnetNiger.db"
  },
  "Admin": {
    "ApiKey": ""
  },
  "Jwt": {
    "Issuer": "DotnetNiger.Identity",
    "Audience": "DotnetNiger.Identity.Client",
    "Key": "DevOnly_DotnetNiger_SuperSecretKey_2026!MinLength32"
  },
  "IdentityApi": {
    "BaseUrl": "http://localhost:5075/"
  },
  "AllowedOrigins": ["http://localhost:5000"],
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/community-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
