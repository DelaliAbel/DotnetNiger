* text=auto

# C# files
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf

# JSON files
*.json text eol=lf
*.jsonc text eol=lf

# Markdown files
*.md text eol=lf

# Shell scripts
*.sh text eol=lf
*.ps1 text eol=crlf

# YAML files
*.yml text eol=lf
*.yaml text eol=lf

# Docker
Dockerfile text eol=lf
.dockerignore text eol=lf
docker-compose.yml text eol=lf
docker-compose.*.yml text eol=lf

# Binary files
*.dll binary
*.exe binary
*.pdb binary
*.zip binary
*.gz binary
*.tar binary

# Image files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.db binary
*.ldf binary
*.mdf binary
