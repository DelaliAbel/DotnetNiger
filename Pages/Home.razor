@page "/"
@* Page d'accueil publique du site .NET Niger. *@

<PageTitle>Accueil - .NET Niger</PageTitle>
<div class="relative min-h-screen bg-[url('/Images/Fond.jpeg')] bg-cover bg-center">

  <!-- Overlay sombre optionnel -->
  <div class="bg-[#FFFFFF]/40 absolute inset-0"></div>

  <!-- Contenu -->
  <div class="relative block min-h-screen items-center justify-center px-4">

      <h1 class="mb-4 text-4xl font-bold">
        Bienvenue sur mon site
      </h1>

      <p class="mb-6 text-gray-700">
        Construisons ensemble des solutions modernes et performantes.
      </p>

      <div class="flex justify-center gap-4">
        <button class="rounded-lg bg-blue-600 px-6 py-2 text-white transition hover:bg-blue-700">
          Commencer
        </button>

        <button class="rounded-lg border border-blue-600 px-6 py-2 text-blue-600 transition hover:bg-blue-50">
          En savoir plus
        </button>
      </div>

    </div>

</div>
