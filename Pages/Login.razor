@page "/login"
@* Page d'authentification : connexion utilisateur. *@
@layout DotnetNiger.UI.Layouts.MainLayout
@inject AuthService Auth
@inject NavigationManager Navigation

<PageTitle>Connexion - .NET Niger</PageTitle>

<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4 py-12">
    <div class="w-full max-w-md bg-white rounded-2xl shadow-lg p-8">

        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-gray-800">Connexion</h1>
            <p class="text-gray-500 mt-2">Bienvenue sur .NET Niger</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-red-700 text-sm">
                @errorMessage
            </div>
        }

        <EditForm Model="model" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-1">Adresse e-mail</label>
                <InputText @bind-Value="model.Email" type="email"
                    class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                    placeholder="vous@exemple.com" />
                <ValidationMessage For="@(() => model.Email)" class="text-xs text-red-500 mt-1" />
            </div>

            <div class="mb-6">
                <div class="flex justify-between items-center mb-1">
                    <label class="block text-sm font-medium text-gray-700">Mot de passe</label>
                    <a href="/forgot-password" class="text-xs text-blue-600 hover:underline">
                        Mot de passe oublié ?
                    </a>
                </div>
                <InputText @bind-Value="model.Password" type="password"
                    class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                    placeholder="••••••••" />
                <ValidationMessage For="@(() => model.Password)" class="text-xs text-red-500 mt-1" />
            </div>

            <button type="submit" disabled="@isLoading"
                class="w-full rounded-lg bg-blue-600 py-2.5 text-sm font-semibold text-white hover:bg-blue-700 transition disabled:opacity-60">
                @(isLoading ? "Connexion en cours..." : "Se connecter")
            </button>
        </EditForm>

        <p class="text-center text-sm text-gray-500 mt-6">
            Pas encore de compte ?
            <a href="/register" class="text-blue-600 font-medium hover:underline">S'inscrire</a>
        </p>
    </div>
</div>

@code {
    private LoginRequest model = new();
    private string errorMessage = "";
    private bool isLoading;

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = "";
        var result = await Auth.LoginAsync(model);
        isLoading = false;

        if (result.Success)
        {
            var destination = Auth.GetPostLoginRedirectPath(result.Token?.AccessToken);
            Navigation.NavigateTo(destination);
        }
        else
            errorMessage = result.Message;
    }
}
