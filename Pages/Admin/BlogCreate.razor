@page "/admin/blog/create"
@layout AdminLayout
@inject NavigationManager NavigationManager

<div class="min-h-screen bg-gray-50 p-6">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-3xl font-bold text-gray-800">Blog <span class="text-gray-400">></span> Création</h1>
        <button @onclick='() => NavigationManager.NavigateTo("/admin/blog")' class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-lg flex items-center gap-2 transition">
            <i class="fas fa-arrow-left"></i>
            Retour
        </button>
    </div>

    <div class="bg-white rounded-xl shadow p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Titre</label>
                <input @bind="title" type="text" class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-red-500" />
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Auteur</label>
                <input @bind="author" type="text" class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-red-500" />
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Catégorie</label>
                <select @bind="category" class="w-full border border-gray-300 rounded-lg px-4 py-3 bg-white focus:outline-none focus:ring-2 focus:ring-red-500">
                    <option value="">Sélectionner</option>
                    <option value="Tutorial">Tutorial</option>
                    <option value="Article">Article</option>
                    <option value="Interview">Interview</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Image de couverture</label>
                <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                    <label class="bg-gray-200 text-gray-700 px-4 py-3 text-sm cursor-pointer">
                        Choisir un fichier
                        <input type="file" class="hidden" />
                    </label>
                    <span class="px-3 text-sm text-gray-500">Aucun fichier choisi</span>
                </div>
            </div>
        </div>

        <div class="mt-6">
            <label class="block text-sm font-semibold text-gray-700 mb-2">Description</label>
            <textarea @bind="description" rows="4" class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-red-500"></textarea>
        </div>

        <div class="mt-6">
            <div class="border border-gray-300 rounded-lg">
                <div class="flex flex-wrap items-center gap-3 px-4 py-2 border-b border-gray-200 text-gray-600">
                    <button class="p-1 hover:text-gray-900"><i class="fas fa-undo"></i></button>
                    <button class="p-1 hover:text-gray-900"><i class="fas fa-redo"></i></button>
                    <div class="h-4 w-px bg-gray-300"></div>
                    <select class="border border-gray-300 rounded px-2 py-1 text-sm bg-white">
                        <option>Paragraph</option>
                        <option>Heading 1</option>
                        <option>Heading 2</option>
                    </select>
                    <button class="p-1 hover:text-gray-900 font-bold">B</button>
                    <button class="p-1 hover:text-gray-900 italic">I</button>
                    <button class="p-1 hover:text-gray-900 underline">U</button>
                    <button class="p-1 hover:text-gray-900 line-through">S</button>
                    <button class="p-1 hover:text-gray-900"><i class="fas fa-align-left"></i></button>
                    <button class="p-1 hover:text-gray-900"><i class="fas fa-align-center"></i></button>
                    <button class="p-1 hover:text-gray-900"><i class="fas fa-align-right"></i></button>
                    <button class="p-1 hover:text-gray-900"><i class="fas fa-list-ul"></i></button>
                    <button class="p-1 hover:text-gray-900"><i class="fas fa-list-ol"></i></button>
                    <button class="p-1 hover:text-gray-900"><i class="fas fa-link"></i></button>
                    <button class="p-1 hover:text-gray-900"><i class="fas fa-image"></i></button>
                </div>
                <textarea @bind="content" rows="6" class="w-full px-4 py-3 focus:outline-none rounded-b-lg"></textarea>
            </div>
        </div>

        <div class="mt-6 flex flex-wrap gap-4">
            <button class="bg-blue-500 hover:bg-blue-600 text-white px-6 py-3 rounded-lg flex items-center gap-2 transition">
                <i class="fas fa-save"></i>
                Sauvegarder
            </button>
            <button class="bg-green-500 hover:bg-green-600 text-white px-6 py-3 rounded-lg flex items-center gap-2 transition">
                <i class="fas fa-paper-plane"></i>
                Publier
            </button>
            <button class="bg-gray-700 hover:bg-gray-800 text-white px-6 py-3 rounded-lg flex items-center gap-2 transition">
                <i class="fas fa-eye"></i>
                Aperçu
            </button>
        </div>
    </div>
</div>

@code {
    private string title = "";
    private string author = "";
    private string category = "";
    private string description = "";
    private string content = "";
}
