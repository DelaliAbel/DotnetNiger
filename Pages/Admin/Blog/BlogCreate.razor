@page "/admin/blog/create"
@using DotnetNiger.UI.Components.Admin
@inject NavigationManager NavigationManager

@inject IJSRuntime JS

<div class="min-h-screen bg-gray-50 p-6">
    <div class="mb-6 flex items-center justify-between">
        <span class="H3 text-gray-800">Blog <span class="text-gray-400">></span> Création</span>
        <button @onclick='() => NavigationManager.NavigateTo("/admin/blog")' class="bg-red-500 hover:bg-red-600 text-white min-h-12 px-4 py-2 rounded-lg flex items-center gap-2 transition">
            <i class="fas fa-arrow-left"></i>
            Retour
        </button>
    </div>

    <div class="rounded-xl bg-white p-6 shadow">
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
            <div>
                <label class="mb-2 block text-sm font-semibold text-gray-700">Titre</label>
                <input @bind="title" type="text" class="w-full rounded-lg border border-gray-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-red-500" />
            </div>
            <div>
                <label class="mb-2 block text-sm font-semibold text-gray-700">Catégorie</label>
                <select @bind="category" class="w-full rounded-lg border border-gray-300 bg-white px-4 py-3 focus:outline-none focus:ring-2 focus:ring-red-500">
                    <option value="">Sélectionner</option>
                    <option value="Tutorial">Tutorial</option>
                    <option value="Article">Article</option>
                    <option value="Interview">Interview</option>
                </select>
            </div>
            <div>
                <label class="mb-2 block text-sm font-semibold text-gray-700">Image de couverture</label>
                <div class="flex items-center overflow-hidden rounded-lg border border-gray-300">
                    <label class="cursor-pointer bg-gray-200 px-4 py-3 text-sm text-gray-700">
                        Choisir un fichier
                        <input type="file" class="hidden" />
                    </label>
                    <span class="px-3 text-sm text-gray-500">Aucun fichier choisi</span>
                </div>
            </div>
        </div>


        <div class="mt-6">
            <textarea id="blogDescription" class="w-full min-h-96"></textarea>
        </div>

        <div class="mt-6 flex flex-wrap gap-4">
            <button class="flex items-center gap-2 rounded-lg bg-blue-500 px-6 py-3 text-white transition hover:bg-blue-600">
                <i class="fas fa-save"></i>
                Sauvegarder
            </button>
            <button class="flex items-center gap-2 rounded-lg bg-green-500 px-6 py-3 text-white transition hover:bg-green-600">
                <i class="fas fa-paper-plane"></i>
                Publier
            </button>
            <button class="flex items-center gap-2 rounded-lg bg-gray-700 px-6 py-3 text-white transition hover:bg-gray-800">
                <i class="fas fa-eye"></i>
                Aperçu
            </button>
        </div>
    </div>
</div>

@code {
    private string title = "";
    private string author = "";
    private string category = "";
    private string description = "";
    private string content = "";

     protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JS.InvokeVoidAsync("initTinyMCE", "blogDescription");
            }
            catch (Exception ex)
            {
                Console.Error.WriteLine($"Error initializing TinyMCE: {ex.Message}");
            }
        }
    }
}
