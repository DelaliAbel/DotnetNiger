@page "/admin/dashboard"
@* Page admin : tableau de bord (KPI + listes récentes) alimenté par services. *@
@inject IPostService PostService
@inject IEventService EventService
@inject IResourceService ResourceService
@inject IProfileService ProfileService

<div class="px-4 py-6 md:px-8 md:py-8 bg-[#F4F2F2]">
	@* En-tête principal du dashboard *@
	<section>
		<h1 class="H3 text-black">Tableau De Bord</h1>
		<p class="body-regular text-text">Aperçu rapide des performances et activités clés du site.</p>
	</section>

	@* Cartes de synthèse (KPI) *@
	<section class="mt-10 grid gap-6 sm:grid-cols-2 xl:grid-cols-4">
		@foreach (var metric in Metrics)
		{
			<article class="overflow-hidden rounded-md bg-white shadow-lg">
				<div class="flex flex-col items-center justify-center gap-2 px-6 py-7">
					<i class="@metric.IconClass text-2xl text-indigo-700"></i>
					<p class="H3 leading-none text-text">@metric.Value</p>
					<p class="body-small text-text">@metric.Label</p>
				</div>
				<button type="button" class="w-full bg-[#EEEAFE] hover:bg-hover py-2 Button text-text transition hover:brightness-95">
					Voir Les Détails <i class="fas fa-angle-double-right ml-1"></i>
				</button>
			</article>
		}
	</section>

	@* Listes récentes : événements et articles *@
	<section class="mt-10 grid gap-8 lg:grid-cols-2">
		<article class="rounded-lg bg-white p-4 shadow-lg md:p-5">
			<h2 class="H4 text-black">Evènements</h2>
			<div class="mt-4 space-y-3">
				@foreach (var item in Events)
				{
					<div class="flex items-center justify-between gap-3 bg-gray-100 px-3 py-2 rounded-md">
						<div class="flex min-w-0 items-center gap-3">
							<div class="h-12 w-12 flex-shrink-0 bg-blue-700"></div>
							<div class="min-w-0">
								<p class="truncate Badge text-black">@item.Title</p>
								<p class="text-xs font-semibold text-[#666666]">@item.Author &nbsp; &nbsp; @item.Date</p>
							</div>
						</div>
						<span class="rounded-md bg-[#73F8AB] px-3 py-1.5 Badge text-[#27AE60]">Publié</span>
					</div>
				}
				@if (Events.Count == 0)
				{
					<p class="py-4 text-lg text-text">Aucun évènement disponible.</p>
				}
			</div>
		</article>

		<article class="rounded-lg bg-white p-4 shadow-lg md:p-5">
			<h2 class="H4 text-black">Articles</h2>
			<div class="mt-4 space-y-3">
				@foreach (var item in Articles)
				{
					<div class="flex items-center justify-between gap-3 bg-gray-100 px-3 py-2 rounded-md">
						<div class="flex min-w-0 items-center gap-3">
							<div class="h-12 w-12 flex-shrink-0 bg-blue-700"></div>
							<div class="min-w-0">
								<p class="truncate Badge text-black">@item.Title</p>
								<p class="text-xs font-semibold text-[#666666]">@item.Author &nbsp; &nbsp; @item.Date</p>
							</div>
						</div>
						<span class="rounded-md bg-[#73F8AB] px-3 py-1.5 Badge text-[#27AE60]">Publié</span>
					</div>
				}
				@if (Articles.Count == 0)
				{
					<p class="py-4 text-lg text-text">Aucun article disponible.</p>
				}
			</div>
		</article>
	</section>
</div>

@code {
	// Données affichées dans les cartes KPI.
	private List<DashboardMetric> Metrics { get; set; } =
	[
		new() { IconClass = "fas fa-users", Value = 0, Label = "Utilisateurs" },
		new() { IconClass = "fas fa-calendar-alt", Value = 0, Label = "Événements" },
		new() { IconClass = "fas fa-newspaper", Value = 0, Label = "Blogs" },
		new() { IconClass = "fas fa-newspaper", Value = 0, Label = "Ressources" }
	];

	private List<DashboardItem> Events { get; set; } = [];
	private List<DashboardItem> Articles { get; set; } = [];

	protected override async Task OnInitializedAsync()
	{
		try
		{
			// Chargement via services (mock ou API selon Program.cs / appsettings.json).
			var posts = await PostService.GetPublishedPostsAsync();
			var events = await EventService.GetPublishedEventsAsync();
			var resources = await ResourceService.GetAllResourcesAsync();
			var profile = await ProfileService.GetProfileAsync();

			// Mise à jour des compteurs KPI.
			Metrics =
			[
				new() { IconClass = "fas fa-users", Value = profile is null ? 0 : 1, Label = "Utilisateurs" },
				new() { IconClass = "fas fa-calendar-alt", Value = events.Count, Label = "Événements" },
				new() { IconClass = "fas fa-newspaper", Value = posts.Count, Label = "Blogs" },
				new() { IconClass = "fas fa-newspaper", Value = resources.Count, Label = "Ressources" }
			];

			// Données récentes affichées dans les deux colonnes.
			Events = events
				.OrderByDescending(e => e.StartDate)
				.Take(6)
				.Select(e => new DashboardItem
				{
					Title = e.Title,
					Author = e.OrganizerName,
					Date = e.StartDate.ToString("dd/MM/yyyy HH:mm")
				})
				.ToList();

			Articles = posts
				.OrderByDescending(p => p.PublishedAt)
				.Take(6)
				.Select(p => new DashboardItem
				{
					Title = p.Title,
					Author = p.AuthorName,
					Date = p.PublishedAt.ToString("dd/MM/yyyy HH:mm")
				})
				.ToList();
		}
		catch
		{
			// Fallback simple si un service échoue.
			Events = [];
			Articles = [];
		}
	}

	private sealed class DashboardMetric
	{
		public required string IconClass { get; set; }
		public int Value { get; set; }
		public required string Label { get; set; }
	}

	private sealed class DashboardItem
	{
		public required string Title { get; set; }
		public required string Author { get; set; }
		public required string Date { get; set; }
	}
}