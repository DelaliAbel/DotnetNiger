@page "/admin/blog"
@using DotnetNiger.UI.Components.Admin.Cards
@using DotnetNiger.UI.Models.Responses

<div class="min-h-screen bg-gray-50 p-6 overflow-y-scroll">
    <!-- Header Section -->
    <div class="mb-8">
        <div class="flex items-center justify-between mb-6">
            <h1 class="text-4xl font-bold text-gray-900">Blog</h1>
            <button
                class="bg-red-500 hover:bg-red-600 text-white px-6 py-2 rounded-lg font-semibold flex items-center gap-2 transition">
                <i class="fas fa-plus"></i>
                Nouveau
            </button>
        </div>

        <!-- Search and Filters -->
        <div class="flex flex-col md:flex-row gap-4 items-stretch md:items-center mb-6">
            <!-- Search Bar -->
            <div class="flex-1">
                <div class="relative">
                    <i class="fas fa-search absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                    <input type="text" placeholder="Rechercher un événement..."    
                           class="w-full pl-12 pr-4 py-3 border border-gray-300 rounded-lg focus:outline-none"/>
                </div>
            </div>

            <!-- Filter Dropdowns -->
            <select 
                    class="px-4 py-3 border border-gray-300 rounded-lg bg-white cursor-pointer hover:border-gray-400 focus:outline-none ">
                <option value="">Type de Post </option>
                    <option value="Tutorial">Tutorial</option>
                    <option value="PostDtoostDtoption>
                    <option value=" Interview">Interview</option>
                </select>

                <select 
                        class="px-4 py-3 border border-gray-300 rounded-lg bg-white cursor-pointer hover:border-gray-400 focus:outline-none ">
                    <option value="">Statut</option>
                    <option value="published">Publié</option>
                    <option value="draft">Brouillon</option>
                    <option value="archived">Archivé</option>
                </select>
            </div>

            <!-- View Toggle -->
            <div class="flex gap-3 mb-6">
                <button @onclick='() => viewMode = "list"'
                        class='@(viewMode == "list" ? "bg-gray-900 text-white" : "bg-white text-gray-900 border border-gray-300") px-4 py-2 rounded-lg font-semibold flex items-center gap-2 transition hover:shadow-md'>
                    <i class="fas fa-list"></i>
                    Liste
                </button>
                <button @onclick='() => viewMode = "grid"'
                        class='@(viewMode == "grid" ? "bg-gray-900 text-white" : "bg-white text-gray-900 border border-gray-300") px-4 py-2 rounded-lg font-semibold flex items-center gap-2 transition hover:shadow-md'>
                    <i class="fas fa-th"></i>
                    Grille
                </button>
            </div>
        </div>

        
        <!-- Table View -->
        @if (viewMode == "list")
        {
            <BlogTable/>

        }
    </div>

@code {
    
    private string viewMode = "list";

}