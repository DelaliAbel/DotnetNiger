    private IEnumerable<ResourceItem> filteredResources => resources
        .Where(r => string.IsNullOrEmpty(searchQuery) || 
                   r.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                   r.Author.Contains(searchQuery, StringComparison.OrdinalIgnoreCase))
        .Where(r => string.IsNullOrEmpty(selectedStatus) || r.Status == selectedStatus)
        .Where(r => string.IsNullOrEmpty(selectedType) || r.ResourceType == selectedType)
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize);

    private void NavigateToCreate()
    {
        Navigation.NavigateTo("/admin/ressources/nouveau");
    }

    private void ToggleMenu(Guid resourceId)
    {
        openMenuId = openMenuId == resourceId ? null : resourceId;
    }

    private void ViewResource(Guid resourceId)
    {
        openMenuId = null;
        Console.WriteLine($"View resource: {resourceId}");
    }

    private void EditResource(Guid resourceId)
    {
        openMenuId = null;
        Console.WriteLine($"Edit resource: {resourceId}");
    }

    private void DeleteResource(Guid resourceId)
    {
        openMenuId = null;
        Console.WriteLine($"Delete resource: {resourceId}");
    }

    private void PreviousPage()
    {
        if (currentPage > 1) currentPage--;
    }

    private void NextPage()
    {
        if (currentPage < totalPages) currentPage++;
    }

    private void GoToPage(int page)
    {
        currentPage = page;
    }

    // Local model for UI purposes
    public class ResourceItem
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public string Author { get; set; } = string.Empty;
        public string Category { get; set; } = string.Empty;
        public string ResourceType { get; set; } = string.Empty;
        public DateTime PublishedDate { get; set; }
        public string Status { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
    }
