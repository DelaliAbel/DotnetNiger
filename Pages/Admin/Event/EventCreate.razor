@page "/admin/events/nouveau"
@using DotnetNiger.UI.Models.Requests
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="p-6">
    <!-- Header -->
    <div class="flex justify-between items-center mb-6">
        <div class="flex items-center gap-3">
            <h1 class="H3">Gestion des événements</h1>
            <i class="fas fa-chevron-right text-gray-400"></i>
            <span class="H3">Nouveau</span>
        </div>
        <button @onclick="GoBack" class="bg-red-500 hover:bg-red-600 text-white min-h-12 px-4 py-2 rounded-lg flex items-center gap-2">
            <i class="fas fa-arrow-left text-2xl"></i>
            <span class="Button">Retour</span>
            
        </button>
    </div>

    <!-- Form -->
    <div class="bg-white rounded-lg shadow p-6">
        <EditForm Model="@eventRequest" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
                <!-- Titre -->
                <div>
                    <label class="block text-sm font-semibold mb-2">Titre</label>
                    <InputText @bind-Value="eventRequest.Title" 
                              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" 
                              placeholder="Titre de l'événement" />
                    <ValidationMessage For="@(() => eventRequest.Title)" class="text-red-500 text-sm mt-1" />
                </div>

                <!-- Lieu -->
                <div>
                    <label class="block text-sm font-semibold mb-2">Lieu</label>
                    <InputText @bind-Value="eventRequest.Location" 
                              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" 
                              placeholder="Lieu de l'événement" />
                </div>

                <!-- Capacité -->
                <div>
                    <label class="block text-sm font-semibold mb-2">Capacité</label>
                    <InputNumber @bind-Value="eventRequest.Capacity" 
                                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" 
                                placeholder="100" />
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <!-- Auteur / Organisateur -->
                <div>
                    <label class="block text-sm font-semibold mb-2">Auteur</label>
                    <InputText @bind-Value="organizerName" 
                              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" 
                              placeholder="Nom de l'organisateur" />
                </div>

                <!-- Image de couverture -->
                <div>
                    <label class="block text-sm font-semibold mb-2">Image de couverture</label>
                    <div class="flex gap-2">
                        <button type="button" 
                               @onclick="SelectFile"
                               class="bg-gray-300 hover:bg-gray-400 px-6 py-2 rounded-lg text-gray-700">
                            Choisir un fichier
                        </button>
                        <input type="text" 
                              @bind="eventRequest.CoverImageUrl" 
                              class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" 
                              placeholder="URL de l'image" 
                              readonly />
                    </div>
                    <InputFile OnChange="HandleFileSelected" 
                              id="fileInput" 
                              class="hidden" 
                              accept="image/*" />
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <!-- Catégorie -->
                <div>
                    <label class="block text-sm font-semibold mb-2">Catégorie</label>
                    <InputSelect @bind-Value="eventRequest.EventType" 
                                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
                        <option value="">Sélectionner une catégorie</option>
                        <option value="Présentation">Présentation</option>
                        <option value="Meeting">Meeting</option>
                        <option value="Hackathon">Hackathon</option>
                        <option value="Challenge">Challenge</option>
                        <option value="Conférence">Conférence</option>
                        <option value="Workshop">Workshop</option>
                        <option value="Webinaire">Webinaire</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => eventRequest.EventType)" class="text-red-500 text-sm mt-1" />
                </div>

                <!-- Type (Online/Présentiel/Hybride) -->
                <div>
                    <label class="block text-sm font-semibold mb-2">Type</label>
                    <InputSelect @bind-Value="eventRequest.MeetupLink" 
                                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
                        <option value="">Présentiel</option>
                        <option value="online">En ligne</option>
                        <option value="hybrid">Hybride</option>
                    </InputSelect>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <!-- Date du début -->
                <div>
                    <label class="block text-sm font-semibold mb-2">Date du début</label>
                    <div class="relative">
                        <InputDate @bind-Value="eventRequest.StartDate" 
                                  Type="InputDateType.DateTimeLocal"
                                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" />
                        <i class="fas fa-calendar-alt absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 pointer-events-none"></i>
                    </div>
                    <ValidationMessage For="@(() => eventRequest.StartDate)" class="text-red-500 text-sm mt-1" />
                </div>

                <!-- Date de fin -->
                <div>
                    <label class="block text-sm font-semibold mb-2">Date de fin</label>
                    <div class="relative">
                        <InputDate @bind-Value="eventRequest.EndDate" 
                                  Type="InputDateType.DateTimeLocal"
                                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" />
                        <i class="fas fa-calendar-alt absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 pointer-events-none"></i>
                    </div>
                    <ValidationMessage For="@(() => eventRequest.EndDate)" class="text-red-500 text-sm mt-1" />
                </div>
            </div>

            <!-- Description avec TinyMCE -->
            <div class="mb-6">
                <label class="block text-sm font-semibold mb-2">Description</label>
                <textarea id="eventDescription" class="w-full"></textarea>
                <ValidationMessage For="@(() => eventRequest.Description)" class="text-red-500 text-sm mt-1" />
            </div>

            <!-- Action Buttons -->
            <div class="flex gap-4">
                <button type="button" 
                       @onclick="SaveDraft"
                       class="bg-blue-500 hover:bg-blue-600 text-white px-6 py-3 rounded-lg flex items-center gap-2">
                    <i class="fas fa-save"></i>
                    Sauvegarder
                </button>
                <button type="submit" 
                       class="bg-green-500 hover:bg-green-600 text-white px-6 py-3 rounded-lg flex items-center gap-2">
                    <i class="fas fa-bullhorn"></i>
                    Publier
                </button>
                <button type="button" 
                       @onclick="Preview"
                       class="bg-gray-500 hover:bg-gray-600 text-white px-6 py-3 rounded-lg flex items-center gap-2">
                    <i class="fas fa-eye"></i>
                    Aperçu
                </button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private CreateEventRequest eventRequest = new()
    {
        StartDate = DateTime.Now,
        EndDate = DateTime.Now.AddHours(2),
        Capacity = 100
    };
    
    private string organizerName = string.Empty;
    private string selectedFileName = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JS.InvokeVoidAsync("initTinyMCE", "eventDescription");
            }
            catch (Exception ex)
            {
                Console.Error.WriteLine($"Error initializing TinyMCE: {ex.Message}");
            }
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/admin/events");
    }

    private void SelectFile()
    {
        JS.InvokeVoidAsync("document.getElementById('fileInput').click()");
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            selectedFileName = file.Name;
            // TODO: Upload file to server and get URL
            eventRequest.CoverImageUrl = $"/uploads/{file.Name}";
            StateHasChanged();
        }
    }

    private async Task SaveDraft()
    {
        try
        {
            // Get content from TinyMCE
            eventRequest.Description = await JS.InvokeAsync<string>("getTinyMCEContent", "eventDescription");
            eventRequest.IsPublished = false;

            // TODO: Call API to save draft
            Console.WriteLine("Saving draft...");
            Console.WriteLine($"Title: {eventRequest.Title}");
            Console.WriteLine($"Description: {eventRequest.Description}");
            
            // Show success message
            await JS.InvokeVoidAsync("alert", "Brouillon sauvegardé avec succès !");
            
            GoBack();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error saving draft: {ex.Message}");
            await JS.InvokeVoidAsync("alert", "Erreur lors de la sauvegarde du brouillon");
        }
    }

    private async Task HandleSubmit()
    {
        try
        {
            // Get content from TinyMCE
            eventRequest.Description = await JS.InvokeAsync<string>("getTinyMCEContent", "eventDescription");
            eventRequest.IsPublished = true;

            // TODO: Call API to create event
            Console.WriteLine("Publishing event...");
            Console.WriteLine($"Title: {eventRequest.Title}");
            Console.WriteLine($"Description: {eventRequest.Description}");
            Console.WriteLine($"Start Date: {eventRequest.StartDate}");
            Console.WriteLine($"End Date: {eventRequest.EndDate}");
            
            // Show success message
            await JS.InvokeVoidAsync("alert", "Événement publié avec succès !");
            
            GoBack();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error publishing event: {ex.Message}");
            await JS.InvokeVoidAsync("alert", "Erreur lors de la publication de l'événement");
        }
    }

    private async Task Preview()
    {
        try
        {
            // Get content from TinyMCE
            eventRequest.Description = await JS.InvokeAsync<string>("getTinyMCEContent", "eventDescription");
            
            // TODO: Open preview in modal or new page
            await JS.InvokeVoidAsync("alert", $"Aperçu de: {eventRequest.Title}\n\n{eventRequest.Description}");
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error showing preview: {ex.Message}");
        }
    }
}
