@page "/admin/events"
@using DotnetNiger.UI.Components.Admin.Cards
@inject NavigationManager NavigationManager

<div class="p-6">
    <!-- Header -->
    <div class="flex justify-between items-center mb-6">
        <span class="H3">Gestion des événements</span>
        <button @onclick='() => NavigationManager.NavigateTo("/admin/events/nouveau")' class="bg-red-500 hover:bg-red-600 text-white min-h-12 px-4 py-2 rounded-lg flex items-center gap-2">
            <i class="fas fa-plus text-2xl"></i>
            <span class="Button">Nouveau</span>
            
        </button>
    </div>

    <!-- Filters and Search -->
    <div class="flex gap-4 mb-6">
        <!-- Search Bar -->
        <div class="flex-1 relative">
            <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
            <input 
                type="text" 
                placeholder="Rechercher un événement..." 
                @bind="searchQuery"
                @bind:event="oninput"
                class="w-1/2 min-w-[455px] py-3 pl-12 pr-4 border  border-gray-300 rounded-lg focus:outline-none"
            />
        </div>

        <!-- Status Filter -->
        <select @bind="selectedStatus" class="px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="">Tous</option>
            <option value="published">Publié</option>
            <option value="pending">Attente</option>
            <option value="archived">Archivé</option>
        </select>

        <!-- Type Filter -->
        <select @bind="selectedType" class="px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="">Type</option>
            <option value="online">En ligne</option>
            <option value="onsite">Présentiel</option>
            <option value="hybrid">Hybride</option>
        </select>

        <!-- Period Filter -->
        <select @bind="selectedPeriod" class="px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="">Période</option>
            <option value="today">Aujourd'hui</option>
            <option value="week">Cette semaine</option>
            <option value="month">Ce mois</option>
            <option value="year">Cette année</option>
        </select>
    </div>

    <!-- View Toggle -->
    <div class="flex gap-2 mb-6">
        <button 
            @onclick="() => isListView = true"
            class="@(isListView ? "bg-black text-white" : "bg-white text-black border border-gray-300") px-4 py-2 rounded-lg flex items-center gap-2">
            <i class="fas fa-list text-2xl"></i>
            
        </button>
        <button 
            @onclick="() => isListView = false"
            class="@(!isListView ? "bg-black text-white" : "bg-white text-black border border-gray-300") px-4 py-2 rounded-lg flex items-center gap-2">
            <i class="fas fa-th text-2xl"></i>
        </button>
    </div>

    @if (isListView)
    {
        <!-- List View (Table) -->
        <div class="bg-white rounded-lg shadow overflow-hidden">
            <table class="w-full">
                <thead class="bg-gray-50 border-b">
                    <tr>
                        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Événement</th>
                        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Organisateur</th>
                        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Catégorie</th>
                        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Type</th>
                        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Date</th>
                        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Statut</th>
                        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Inscrits</th>
                        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0 ; i < 6 ; i++)
                    {
                        <tr class="border-b hover:bg-gray-50">
                            <td class="px-6 py-4 text-sm">Introduction à .Net</td>
                            <td class="px-6 py-4 text-sm">Ali Mahamane</td>
                            <td class="px-6 py-4 text-sm">Présentation</td>
                            <td class="px-6 py-4 text-sm">
                                    <span>En ligne</span>
                            </td>
                            <td class="px-6 py-4 text-sm whitespace-nowrap">15/01/2025  12:30</td>
                            <td class="px-6 py-4 text-sm">
                                    <span class="flex items-center gap-2">
                                        <span class="w-3 h-3 bg-green-500 rounded-full"></span>
                                        Publié
                                    </span>
                            </td>
                            <td class="px-6 py-4 text-sm">12</td>
                            <td class="px-6 py-4 text-sm">
                                <div class="flex gap-2">
                                    <button  class="text-gray-600 hover:text-blue-600" title="Voir">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                    <button  class="text-gray-600 hover:text-blue-600" title="Éditer">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button class="text-gray-600 hover:text-red-600" title="Supprimer">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <!-- Grid View (Cards) -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @for(var i = 0;i > 6;i++)
            {
                <EventCard />
                <BlogCard />
            }
        </div>
    }

</div>

@code {
    private bool isListView = true;
    private string searchQuery = string.Empty;
    private string selectedStatus = string.Empty;
    private string selectedType = string.Empty;
    private string selectedPeriod = string.Empty;

 
}
