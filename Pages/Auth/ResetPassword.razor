@page "/reset-password"
@* Page d'authentification : saisie du nouveau mot de passe avec token. *@
@inject AuthService Auth
@inject NavigationManager Navigation

<PageTitle>Réinitialiser le mot de passe - .NET Niger</PageTitle>

<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4 py-12">
    <div class="w-full max-w-md bg-white rounded-2xl shadow-lg p-8">

        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-gray-800">Nouveau mot de passe</h1>
            <p class="text-gray-500 mt-2">Saisissez votre nouveau mot de passe ci-dessous.</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-red-700 text-sm">
                @errorMessage
            </div>
        }

        <EditForm Model="model" OnValidSubmit="HandleReset">
            <DataAnnotationsValidator />

            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-1">Adresse e-mail</label>
                <InputText @bind-Value="model.Email" type="email"
                    class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                    placeholder="vous@exemple.com" />
                <ValidationMessage For="@(() => model.Email)" class="text-xs text-red-500 mt-1" />
            </div>

            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-1">Token de réinitialisation</label>
                <InputText @bind-Value="model.Token"
                    class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                    placeholder="Token reçu par email" />
                <ValidationMessage For="@(() => model.Token)" class="text-xs text-red-500 mt-1" />
            </div>

            <div class="mb-6">
                <label class="block text-sm font-medium text-gray-700 mb-1">Nouveau mot de passe</label>
                <InputText @bind-Value="model.NewPassword" type="password"
                    class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                    placeholder="Minimum 8 caractères" />
                <ValidationMessage For="@(() => model.NewPassword)" class="text-xs text-red-500 mt-1" />
            </div>

            <button type="submit" disabled="@isLoading"
                class="w-full rounded-lg bg-blue-600 py-2.5 text-sm font-semibold text-white hover:bg-blue-700 transition disabled:opacity-60">
                @(isLoading ? "Réinitialisation..." : "Réinitialiser le mot de passe")
            </button>
        </EditForm>
    </div>
</div>

@code {
    private ResetPasswordRequest model = new();
    private string errorMessage = "";
    private bool isLoading;

    // Pré-remplissage depuis les query params: /reset-password?token=xxx&email=yyy
    [Parameter, SupplyParameterFromQuery] public string? Token { get; set; }
    [Parameter, SupplyParameterFromQuery] public string? Email { get; set; }

    protected override void OnInitialized()
    {
        if (!string.IsNullOrWhiteSpace(Token)) model.Token = Token;
        if (!string.IsNullOrWhiteSpace(Email)) model.Email = Email;
    }

    private async Task HandleReset()
    {
        isLoading = true;
        errorMessage = "";
        var result = await Auth.ResetPasswordAsync(model);
        isLoading = false;

        if (result.Success)
            Navigation.NavigateTo("/login");
        else
            errorMessage = result.Message ?? "Erreur lors de la réinitialisation.";
    }
}
