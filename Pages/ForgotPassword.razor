@page "/forgot-password"
@* Page d'authentification : demande de lien de réinitialisation de mot de passe. *@
@layout DotnetNiger.UI.Layouts.MainLayout
@inject AuthService Auth

<PageTitle>Mot de passe oublié - .NET Niger</PageTitle>

<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4 py-12">
    <div class="w-full max-w-md bg-white rounded-2xl shadow-lg p-8">

        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-gray-800">Mot de passe oublié</h1>
            <p class="text-gray-500 mt-2">Renseignez votre email pour recevoir un lien de réinitialisation.</p>
        </div>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="mb-4 rounded-lg border px-4 py-3 text-sm @(isSuccess ? "bg-green-50 border-green-200 text-green-700" : "bg-red-50 border-red-200 text-red-700")">
                @message
            </div>
        }

        <EditForm Model="model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div class="mb-6">
                <label class="block text-sm font-medium text-gray-700 mb-1">Adresse e-mail</label>
                <InputText @bind-Value="model.Email" type="email"
                    class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition"
                    placeholder="vous@exemple.com" />
                <ValidationMessage For="@(() => model.Email)" class="text-xs text-red-500 mt-1" />
            </div>

            <button type="submit" disabled="@isLoading"
                class="w-full rounded-lg bg-blue-600 py-2.5 text-sm font-semibold text-white hover:bg-blue-700 transition disabled:opacity-60">
                @(isLoading ? "Envoi en cours..." : "Envoyer le lien")
            </button>
        </EditForm>

        <p class="text-center text-sm text-gray-500 mt-6">
            <a href="/login" class="text-blue-600 font-medium hover:underline">Retour à la connexion</a>
        </p>
    </div>
</div>

@code {
    private ForgotPasswordRequest model = new();
    private string message = "";
    private bool isSuccess;
    private bool isLoading;

    private async Task HandleSubmit()
    {
        isLoading = true;
        message = "";
        isSuccess = await Auth.ForgotPasswordAsync(model);
        isLoading = false;
        message = isSuccess
            ? "Un email de réinitialisation a été envoyé à votre adresse."
            : "Aucun compte associé à cet email.";
    }
}
