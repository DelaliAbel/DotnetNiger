### Health Check (Public)
GET {{DotnetNiger.Identity_HostAddress}}/api/v1/health

### Health Check Detailed (Admin)
GET {{DotnetNiger.Identity_HostAddress}}/api/v1/health/detailed
Authorization: Bearer {{token}}

### Diagnostics Status (Public)
GET {{DotnetNiger.Identity_HostAddress}}/api/v1/diagnostics/status

# ==============================================================================
# 8. ROLES (Legacy endpoints - 5 endpoints)
# ==============================================================================

### Get All Roles
GET {{DotnetNiger.Identity_HostAddress}}/api/v1/roles
Authorization: Bearer {{token}}

### Create Role
POST {{DotnetNiger.Identity_HostAddress}}/api/v1/roles
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Editor"
}

### Delete Role
DELETE {{DotnetNiger.Identity_HostAddress}}/api/v1/roles/{{roleId}}
Authorization: Bearer {{token}}

### Assign Role
POST {{DotnetNiger.Identity_HostAddress}}/api/v1/roles/assign
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "userId": "user-guid-here",
  "roleName": "Editor"
}

### Remove Role
POST {{DotnetNiger.Identity_HostAddress}}/api/v1/roles/remove
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "userId": "user-guid-here",
  "roleName": "Editor"
}

### Get User Roles
GET {{DotnetNiger.Identity_HostAddress}}/api/v1/roles/user/{{userId}}
Authorization: Bearer {{token}}

# ==============================================================================
# 9. PERMISSIONS (Legacy endpoints - 5 endpoints)
# ==============================================================================

### Get All Permissions
GET {{DotnetNiger.Identity_HostAddress}}/api/v1/permissions
Authorization: Bearer {{token}}

### Create Permission
POST {{DotnetNiger.Identity_HostAddress}}/api/v1/permissions
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "CanPublish",
  "description": "Can publish content"
}

### Delete Permission
DELETE {{DotnetNiger.Identity_HostAddress}}/api/v1/permissions/{{permissionId}}
Authorization: Bearer {{token}}

### Assign Permission to Role
POST {{DotnetNiger.Identity_HostAddress}}/api/v1/permissions/assign
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "roleId": "role-guid-here",
  "permissionId": "permission-guid-here"
}

### Remove Permission from Role
POST {{DotnetNiger.Identity_HostAddress}}/api/v1/permissions/remove
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "roleId": "role-guid-here",
  "permissionId": "permission-guid-here"
}

### Get Role Permissions
GET {{DotnetNiger.Identity_HostAddress}}/api/v1/permissions/role/{{roleId}}
Authorization: Bearer {{token}}

# ==============================================================================
# 10. SOCIAL LINKS (3 endpoints)
# ==============================================================================

### Get My Social Links
GET {{DotnetNiger.Identity_HostAddress}}/api/v1/social-links
Authorization: Bearer {{token}}

### Add Social Link
POST {{DotnetNiger.Identity_HostAddress}}/api/v1/social-links
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "platform": "Twitter",
  "url": "https://twitter.com/username"
}

### Delete Social Link
DELETE {{DotnetNiger.Identity_HostAddress}}/api/v1/social-links/{{socialLinkId}}
Authorization: Bearer {{token}}

