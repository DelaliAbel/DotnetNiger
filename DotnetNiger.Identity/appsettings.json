{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/identity-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DotnetNigerIdentityContextConnection": "Server=(localdb)\\mssqllocaldb;Database=DotnetNiger.Identity;Trusted_Connection=True;MultipleActiveResultSets=true",
    "DotnetNigerIdentityContext": "Data Source=DotnetNigerIdentityContext-7087f966-a137-4f83-b877-de4da77d1a28.db",
    "DotnetNigerIdentityDbContext": "Data Source=Infrastructure/Data/DotnetNigerIdentityDb.db"
  },
  "Jwt": {
    "Issuer": "DotnetNiger.Identity",
    "Audience": "DotnetNiger.Identity.Client",
    "Key": "CHANGE_ME_AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },
  "Email": {
    "Enabled": false,
    "Provider": "smtp",
    "Smtp": {
      "Host": "",
      "Port": 587,
      "Username": "",
      "Password": "CHANGE_ME",
      "From": "",
      "EnableSsl": true
    },
    "SendGrid": {
      "ApiKey": "",
      "From": ""
    },
    "Mailgun": {
      "ApiKey": "",
      "Domain": "",
      "From": ""
    }
  },
  "FileUpload": {
    "Provider": "Local",
    "RootPath": "uploads",
    "PublicBasePath": "/uploads",
    "MaxAvatarBytes": 2000000,
    "AllowedAvatarContentTypes": ["image/jpeg", "image/png", "image/webp"],
    "AllowedAvatarExtensions": [".jpg", ".jpeg", ".png", ".webp"],
    "CleanupEnabled": false,
    "CleanupIntervalMinutes": 1440,
    "CleanupOrphanDays": 7,
    "Azure": {
      "ConnectionString": "",
      "Container": "dotnetniger-uploads",
      "PublicBaseUrl": ""
    }
  }
}
